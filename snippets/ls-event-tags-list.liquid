{% doc %}
Returns normalized tag array string for data attributes (comma-separated).
@param {metaobject} event
{% enddoc %}

{%- liquid
  assign tags_raw = event.tags.value
  if tags_raw == blank
    assign tags_raw = event.tags
  endif
  if tags_raw.value != blank
    assign tags_raw = tags_raw.value
  endif

  assign tags_joined = ''

  if tags_raw.first
    assign tags_joined = tags_raw | join: ','
  elsif tags_raw != blank
    if tags_raw contains '["'
      assign tags_parsed = tags_raw | parse_json
      assign tags_joined = tags_parsed | join: ','
    else
      assign tags_joined = tags_raw
    endif
  endif
-%}
{{- tags_joined -}}
