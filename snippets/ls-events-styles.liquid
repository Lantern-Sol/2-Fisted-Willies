{% stylesheet %}
  .ls-events__bg {
    background-color: var(--ls-events-bg, #0e1018);
  }

  .ls-events__inner {
    display: flex;
    flex-direction: column;
    gap: 32px;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding-inline: 24px;
    box-sizing: border-box;
  }

  .ls-events__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }

  .ls-events__title {
    margin: 0;
    display: flex;
    flex-direction: column;
    line-height: 0.85;
    letter-spacing: -0.04em;
  }

  .ls-events__title-1 {
    font-family: var(--font-gashroad--family);
    font-weight: 400;
    font-size: clamp(2.5rem, 10vw, 96px);
    
    color: var(--ls-events-heading, #eae8f0);
  }

  .ls-events__title-2 {
    font-family: var(--font-cormorant-garamond-italic--family);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 8vw, 72px);
    color: var(--ls-events-heading-accent, #7e9de4);
  }

  .ls-events__title--accent-first {
    display: grid;
    justify-items: center;
    align-items: center;
    line-height: 1;
  }

  .ls-events__title--accent-first .ls-events__title-2 {
    grid-area: 1 / 1;
    z-index: 0;
    font-size: clamp(1.75rem, 5vw, 48px);
    transform: translateY(-0.35em);
  }

  .ls-events__title--accent-first .ls-events__title-1 {
    grid-area: 1 / 1;
    z-index: 1;
    transform: translateY(0.2em);
  }

  .ls-events__subtitle {
    margin: 0;
    max-width: 420px;
    font-family: var(--font-cormorant-garamond--family);
    font-size: 18px;
    line-height: 1.5;
    color: var(--ls-events-subtitle, #9ca0b8);
  }

  .ls-events__diamond {
    display: block;
    width: 52px;
    height: 1px;
    margin: 0;
    background-color: var(--ls-events-diamond, #0033a0);
    color: transparent;
    font-size: 0;
    line-height: 0;
    overflow: hidden;
  }

  .ls-events__featured-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ls-events__toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px 24px;
    margin-bottom: 24px;
  }

  .ls-events__filters {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ls-events__filter-group {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .ls-events__filter {
    box-sizing: border-box;
    padding: 8px 14px;
    border: 1px solid var(--ls-events-filter-border, #3d4a66);
    background: transparent;
    color: var(--ls-events-text, #eae8f0);
    font-family: var(--font-body--family);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .ls-events__filter:hover,
  .ls-events__filter:focus-visible {
    border-color: var(--ls-events-heading-accent, #7e9de4);
    outline: none;
  }

  .ls-events__filter.is-active {
    background-color: var(--ls-events-filter-active, rgba(126, 157, 228, 0.15));
    border-color: var(--ls-events-heading-accent, #7e9de4);
  }

  .ls-events__count {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.65px;
    text-transform: uppercase;
    color: var(--ls-events-muted, #9ca0b8);
    white-space: nowrap;
  }

  .ls-events__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .ls-events__grid [hidden] {
    display: none !important;
  }

  .ls-events__empty {
    margin: 24px 0 0;
    text-align: center;
    font-family: var(--font-body--family);
    font-size: 14px;
    color: var(--ls-events-muted, #9ca0b8);
  }

  .ls-events__footer-link-wrap {
    display: flex;
    justify-content: center;
    width: 100%;
    margin-top: 8px;
  }

  .ls-events__footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35em;
    font-family: var(--font-body--family);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1.65px;
    text-transform: uppercase;
    text-decoration: underline;
    text-underline-offset: 4px;
    color: var(--ls-events-footer-link, var(--ls-events-heading-accent, #7e9de4));
    transition: opacity 0.2s ease;
  }

  .ls-events__footer-link:hover {
    opacity: 0.85;
  }

  .ls-events__footer-link-arrow {
    text-decoration: none;
  }

  .ls-events__archive-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
  }

  .ls-events__archive-title {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: 0.25em 0.5em;
    line-height: 1;
  }

  .ls-events__archive-title-1 {
    font-family: var(--font-cormorant-garamond-italic--family);
    font-style: italic;
    font-size: clamp(1.5rem, 5vw, 40px);
    color: var(--ls-events-heading-accent, #7e9de4);
  }

  .ls-events__archive-title-2 {
    font-family: var(--font-gashroad--family);
    font-size: clamp(2rem, 8vw, 72px);
    text-transform: uppercase;
    color: var(--ls-events-heading, #eae8f0);
  }

  .ls-events__archive-subtitle {
    margin: 0;
    max-width: 400px;
    font-family: var(--font-cormorant-garamond--family);
    font-size: 16px;
    color: var(--ls-events-subtitle, #9ca0b8);
  }

  .ls-event-card {
    box-sizing: border-box;
    background-color: var(--ls-events-card-bg, #141824);
    border: 1px solid var(--ls-events-card-border, #2a3348);
    color: var(--ls-events-text, #eae8f0);
  }

  .ls-event-card__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ls-event-card__image--placeholder {
    background: linear-gradient(135deg, #1e2436 0%, #0e1018 100%);
    min-height: 180px;
  }

  .ls-event-card__name {
    margin: 0;
    font-family: var(--font-gashroad--family);
    font-weight: 400;
    font-size: clamp(1.5rem, 4vw, 32px);
    line-height: 1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--ls-events-heading, #eae8f0);
  }

  .ls-event-card__genre {
    margin: 0;
    font-family: var(--font-cormorant-garamond--family);
    font-style: italic;
    font-weight: 500;
    font-size: 14px;
    line-height: 1.4;
    color: var(--ls-events-subtitle, #9ca0b8);
  }

  .ls-event-card__date,
  .ls-event-card__show,
  .ls-event-card__quick,
  .ls-event-card__age {
    font-family: var(--font-body--family);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--ls-events-muted, #9ca0b8);
  }

  .ls-event-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    box-sizing: border-box;
    width: 100%;
    padding: 14px 20px;
    border: 0;
    background-color: var(--ls-events-cta-bg, #0b4bba);
    color: var(--ls-events-cta-text, #eae8f0);
    font-family: var(--font-body--family);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .ls-event-card__cta:hover {
    opacity: 0.9;
  }

  .ls-event-card__cta--ended,
  .ls-event-card__cta--sold-out {
    background-color: #1e2436;
    color: var(--ls-events-muted, #6b7289);
    cursor: default;
    pointer-events: none;
  }

  .ls-event-tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 8px;
    font-family: var(--font-body--family);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    line-height: 1;
  }

  .ls-event-tag__icon {
    display: inline-flex;
    flex-shrink: 0;
  }

  .ls-event-tag--featured {
    background-color: #6b4f1d;
    color: #e8d5a3;
  }

  .ls-event-tag--available {
    background-color: #0d1f14;
    border: 1px solid #3ecf6e;
    color: #3ecf6e;
  }

  .ls-event-tag--pre_sale {
    background-color: #0b4bba;
    color: #eae8f0;
  }

  .ls-event-tag--cover {
    background-color: #141824;
    border: 1px solid #9ca0b8;
    color: #9ca0b8;
  }

  .ls-event-tag--sold_out {
    background-color: #2a1215;
    border: 1px solid #e85d5d;
    color: #e85d5d;
  }

  .ls-event-tag--past {
    background-color: #141824;
    border: 1px solid #6b7289;
    color: #6b7289;
  }

  .ls-event-card--featured {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    align-items: center;
    gap: 20px 24px;
    padding: 16px;
  }

  .ls-event-card--featured .ls-event-card__media {
    width: 140px;
    height: 140px;
    overflow: hidden;
  }

  .ls-event-card--featured .ls-event-card__meta-top {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }

  .ls-event-card--featured .ls-event-card__body {
    min-width: 0;
  }

  .ls-event-card--featured .ls-event-card__quick {
    margin: 12px 0 0;
  }

  .ls-event-card--featured .ls-event-card__age {
    margin-left: 8px;
  }

  .ls-event-card--featured .ls-event-card__actions {
    flex-shrink: 0;
  }

  .ls-event-card--featured .ls-event-card__cta {
    width: auto;
    min-width: 160px;
    white-space: nowrap;
  }

  .ls-event-card--grid,
  .ls-event-card--past {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .ls-event-card--grid {
    border: 1.108px solid var(--ls-events-card-border, #9ca0b8);
    background-color: #474b62;
    background-image:
      linear-gradient(0deg, rgba(30, 35, 54, 0.75) 0%, rgba(30, 35, 54, 0.75) 100%),
      linear-gradient(0deg, #474b62 0%, #474b62 100%);
    background-blend-mode: normal, multiply;
    padding: 12px;
  }

  .ls-event-card--past {
    border: 1.108px solid var(--ls-events-card-border, #9ca0b8);
    padding: 12px;
  }

  .ls-event-card--grid .ls-event-card__media,
  .ls-event-card--past .ls-event-card__media {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .ls-event-card--grid .ls-event-card__badges,
  .ls-event-card--past .ls-event-card__badges {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 1;
  }

  .ls-event-card--grid .ls-event-card__content,
  .ls-event-card--past .ls-event-card__content {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 5px 0 0;
    flex: 1;
  }

  .ls-event-card--grid .ls-event-card__info-row,
  .ls-event-card--past .ls-event-card__info-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 8px;
  }

  .ls-event-card--grid .ls-event-card__date,
  .ls-event-card--past .ls-event-card__date {
    justify-self: start;
    font-size: 12px;
    min-width: 100px;
  }

  .ls-event-card--grid .ls-event-card__show,
  .ls-event-card--past .ls-event-card__show {
    justify-self: center;
    text-align: center;
    font-size: 11px;
  }

  .ls-event-card--grid .ls-event-card__age,
  .ls-event-card--past .ls-event-card__age {
    justify-self: end;
    font-size: 11px;
  }

  .ls-event-card--grid .ls-event-card__genre,
  .ls-event-card--past .ls-event-card__genre {
    color: #9ca0b8;
    font-size: 20px;
    line-height: 24px;
    margin-top: -16px;
  }

  .ls-event-card--grid .ls-event-card__cta,
  .ls-event-card--past .ls-event-card__cta {
    margin-top: auto;
  }

  @media screen and (max-width: 989px) {
    .ls-events__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 749px) {
    .ls-events__inner {
      padding-inline: 16px;
    }

    .ls-events__grid {
      grid-template-columns: 1fr;
    }

    .ls-event-card--featured {
      grid-template-columns: 100px 1fr;
      grid-template-rows: auto auto;
    }

    .ls-event-card--featured .ls-event-card__media {
      width: 100px;
      height: 100px;
      grid-row: span 2;
    }

    .ls-event-card--featured .ls-event-card__actions {
      grid-column: 2;
    }

    .ls-event-card--featured .ls-event-card__cta {
      width: 100%;
      min-width: 0;
    }

    .ls-events__toolbar {
      flex-direction: column;
      align-items: stretch;
    }

    .ls-events__count {
      text-align: right;
    }
  }
  .ls-events__title--accent-first .ls-events__title-2 {
    transform: none;
    font-size: 84px;
}

.ls-events__title--accent-first .ls-events__title-1 {
    transform: none;
    font-size: 128px;
    line-height: 1em;
    /* order: -1; */
}

h2.ls-events__title.ls-events__title--accent-first {
    display: flex;
    flex-direction: column;
}

span.ls-events__title-1 {}

p {}

p.ls-events__subtitle {
    margin-top: -10px;
}
span.ls-events__title-2 {}
@media screen and (max-width: 768px) {
.ls-events__title--accent-first .ls-events__title-2 {
    font-size: 56px;
}

.ls-events__title--accent-first .ls-events__title-1 {
    font-size: 64px;
}
}


article.ls-event-card.ls-event-card--grid {
    border: 1.108px solid var(--Neutrals-Dark-200, #9CA0B8);
    background: linear-gradient(0deg, rgba(30, 35, 54, 0.75) 0%, rgba(30, 35, 54, 0.75) 100%), linear-gradient(0deg, #474B62 0%, #474B62 100%), url(<path-to-image>) lightgray 50% / cover no-repeat;
    background-blend-mode: normal, multiply, normal;
}

article.ls-event-card {
    background-blend-mode: multiply;
    background: #474B62;
    background: #1E2336BF;
    grid-template-columns: 230px 1fr auto;
    padding: 8px;
    padding-right: 20px;
}

.ls-event-card--featured .ls-event-card__media {
    width: 230px;
    height: 230px;
}

.ls-event-card__body {
    height: 100%;
    padding: 16px 0;
}

p.ls-event-card__genre {
    font-size: 18px;
}

h3.ls-event-card__name {
    font-size: 60px;
}

@media screen and (max-width: 768px) {
p.ls-event-card__genre {
    font-size: 18px;
}

h3.ls-event-card__name {
    font-size: 32px;
}
}
.ls-event-card--featured .ls-event-card__body {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 20px 0;
}
{% endstylesheet %}


