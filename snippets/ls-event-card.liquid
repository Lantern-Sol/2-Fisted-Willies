{% doc %}
Renders an event card.
@param {metaobject} event
@param {string} layout - featured | grid | past
@param {boolean} [filterable] - outputs data attributes for JS filtering
{% enddoc %}

{%- liquid
  assign layout = layout | default: 'grid'

  assign event_name = event.event_name.value
  if event_name == blank
    assign event_name = event.event_name
  endif
  if event_name.value != blank
    assign event_name = event_name.value
  endif

  assign show_time = event.show_time.value
  if show_time == blank
    assign show_time = event.show_time
  endif
  if show_time.value != blank
    assign show_time = show_time.value
  endif

  assign genre = event.genre.value
  if genre == blank
    assign genre = event.genre
  endif
  if genre.value != blank
    assign genre = genre.value
  endif

  assign ticket_url = event.ticket_url.value
  if ticket_url == blank
    assign ticket_url = event.ticket_url
  endif
  if ticket_url.value != blank
    assign ticket_url = ticket_url.value
  endif

  assign category = event.category.value
  if category == blank
    assign category = event.category
  endif
  if category.value != blank
    assign category = category.value
  endif

  assign image = event.image.value
  if image == blank
    assign image = event.image
  endif
  if image.value != blank
    assign image = image.value
  endif

  assign is_featured = false
  assign is_sold_out = false
  assign status_tag = ''

  assign tags_raw = event.tags.value
  if tags_raw == blank
    assign tags_raw = event.tags
  endif
  if tags_raw.value != blank
    assign tags_raw = tags_raw.value
  endif

  if tags_raw.first
    assign tags_list = tags_raw
  elsif tags_raw != blank
    if tags_raw contains '["'
      assign tags_list = tags_raw | parse_json
    else
      assign tags_list = tags_raw | split: ','
    endif
  else
    assign tags_list = '' | split: ''
  endif

  for tag in tags_list
    assign tag_handle = tag | strip | handleize | replace: '-', '_'
    if tag_handle == 'featured'
      assign is_featured = true
    endif
    if tag_handle == 'sold_out'
      assign is_sold_out = true
      assign status_tag = 'sold_out'
    elsif tag_handle == 'pre_sale' and status_tag == blank
      assign status_tag = 'pre_sale'
    elsif tag_handle == 'cover' and status_tag == blank
      assign status_tag = 'cover'
    elsif tag_handle == 'available' and status_tag == blank
      assign status_tag = 'available'
    endif
  endfor

  assign tags_joined = tags_list | join: ','
-%}

{%- capture event_date_iso -%}
  {%- render 'ls-event-date-string', event: event -%}
{%- endcapture -%}
{%- assign event_date_iso = event_date_iso | strip -%}

{%- liquid
  if layout == 'featured'
    assign date_label = event_date_iso | date: '%a %b %d' | upcase
  else
    assign date_label = event_date_iso | date: '%a, %b %d' | upcase
  endif

  assign show_info = 'SHOW'
  if show_time != blank
    assign show_info = show_info | append: ' · ' | append: show_time
  endif
-%}

{%- if layout == 'featured' -%}
  <article
    class="ls-event-card ls-event-card--featured"
    data-event-date="{{ event_date_iso }}"
    {% if filterable %}data-event-card data-category="{{ category }}" data-tags="{{ tags_joined }}"{% endif %}
  >
    <div class="ls-event-card__media">
      {%- if image != blank -%}
        {{ image | image_url: width: 600 | image_tag: class: 'ls-event-card__image', loading: 'lazy', widths: '300,400,600', sizes: '(min-width: 750px) 220px, 120px' }}
      {%- else -%}
        <div class="ls-event-card__image ls-event-card__image--placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    <div class="ls-event-card__body">
      <div class="ls-event-card__meta-top">
        {%- if is_featured -%}
          {% render 'ls-event-tag', tag: 'featured' %}
        {%- endif -%}
        <time class="ls-event-card__date" datetime="{{ event_date_iso }}">{{ date_label }}</time>
      </div>
 <div class="ls-event-card__meta-mid">
      {%- if event_name != blank -%}
        <h3 class="ls-event-card__name">{{ event_name }}</h3>
      {%- endif -%}

      {%- if genre != blank -%}
        <p class="ls-event-card__genre">{{ genre }}</p>
      {%- endif -%}
    </div>

      <p class="ls-event-card__quick">{{ show_info }} <span class="ls-event-card__age">21+</span></p>
    </div>

  {%- unless is_sold_out -%}
    <div class="ls-event-card__actions">
      {%- if ticket_url != blank -%}
        <a class="ls-event-card__cta" href="{{ ticket_url }}" target="_blank" rel="noopener noreferrer">
          Get tickets
          <span class="ls-event-card__cta-arrow" aria-hidden="true">→</span>
        </a>
      {%- endif -%}
    </div>
  {%- endunless -%}
  </article>

{%- else -%}
  <article
    class="ls-event-card ls-event-card--{{ layout }}"
    data-event-date="{{ event_date_iso }}"
    {% if filterable %}data-event-card data-category="{{ category }}" data-tags="{{ tags_joined }}"{% endif %}
  >
    <div class="ls-event-card__media">
      {%- if image != blank -%}
        {{ image | image_url: width: 800 | image_tag: class: 'ls-event-card__image', loading: 'lazy', widths: '400,600,800', sizes: '(min-width: 990px) 33vw, (min-width: 750px) 50vw, 100vw' }}
      {%- else -%}
        <div class="ls-event-card__image ls-event-card__image--placeholder" aria-hidden="true"></div>
      {%- endif -%}

      <div class="ls-event-card__badges">
        {%- if layout == 'past' -%}
          {% render 'ls-event-tag', tag: 'past' %}
        {%- elsif is_featured -%}
          {% render 'ls-event-tag', tag: 'featured' %}
        {%- elsif status_tag != blank -%}
          {% render 'ls-event-tag', tag: status_tag %}
        {%- endif -%}
      </div>
    </div>

    <div class="ls-event-card__content">
      <div class="ls-event-card__info-row">
        <time class="ls-event-card__date" datetime="{{ event_date_iso }}">{{ date_label }}</time>
        <span class="ls-event-card__show">{{ show_info }}</span>
        <span class="ls-event-card__age">21+</span>
      </div>

      {%- if event_name != blank -%}
        <h3 class="ls-event-card__name">{{ event_name }}</h3>
      {%- endif -%}

      {%- if genre != blank -%}
        <p class="ls-event-card__genre">{{ genre }}</p>
      {%- endif -%}

      {%- if layout == 'past' -%}
        <span class="ls-event-card__cta ls-event-card__cta--ended" aria-disabled="true">Event ended</span>
      {%- elsif is_sold_out -%}
        <span class="ls-event-card__cta ls-event-card__cta--sold-out" aria-disabled="true">Sold out</span>
      {%- elsif ticket_url != blank -%}
        <a class="ls-event-card__cta" href="{{ ticket_url }}" target="_blank" rel="noopener noreferrer">
          Get tickets
          <span class="ls-event-card__cta-arrow" aria-hidden="true">→</span>
        </a>
      {%- endif -%}
    </div>
  </article>
{%- endif -%}
