{%- liquid
  assign b = block.settings
-%}

<div class="ls-pic-item{% if b.highlight %} ls-pic-item--highlight{% endif %}" {{ block.shopify_attributes }}>
  <div class="ls-pic-item__img">
    {%- if b.image != blank -%}
      {{
        b.image
        | image_url: width: 120
        | image_tag:
          widths: '40, 80, 120',
          sizes: '42px',
          alt: b.name,
          class: 'ls-pic-item__media',
          loading: 'lazy'
      }}
    {%- endif -%}
  </div>
  {%- if b.name != blank -%}
    <p class="ls-pic-item__name">{{ b.name }}</p>
  {%- endif -%}
</div>

{% stylesheet %}
  .ls-pic-item {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }

  .ls-pic-item__img {
    flex-shrink: 0;
    height: 12px;
    display: flex;
    align-items: center;
  }

  /* Height-locked; width follows the image's natural aspect ratio. */
  .ls-pic-item__media {
    height: 100%;
    width: auto;
    object-fit: contain;
  }

  .ls-pic-item__name {
    margin: 0;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 16px;
    line-height: 1.1;
    letter-spacing: 1.65px;
    text-transform: uppercase;
    color: var(--ls-menu-name, #9ca0b8);
  }

  /* Optional accent for a featured item (e.g. "Craft Standard Margarita · on tap"). */
  .ls-pic-item--highlight .ls-pic-item__name {
    color: var(--ls-menu-highlight, #fac775);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LS Picture Beverage Item",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Logo / can image"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "Budweiser"
    },
    {
      "type": "checkbox",
      "id": "highlight",
      "label": "Highlight (accent color)",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "LS Picture Beverage Item",
      "category": "t:categories.custom"
    }
  ]
}
{% endschema %}
