{%- liquid
  assign b = block.settings
-%}
<details class="ls-faq-item"{% if b.open_by_default %} open{% endif %} {{ block.shopify_attributes }}>
  <summary class="ls-faq-item__summary">
    <span class="ls-faq-item__q">{{ b.question }}</span>
    <span class="ls-faq-item__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M6 9l6 6 6-6" />
      </svg>
    </span>
  </summary>
  {%- if b.answer != blank -%}
    <div class="ls-faq-item__a rte">{{ b.answer }}</div>
  {%- endif -%}
</details>

{% stylesheet %}
  .ls-faq-item {
    width: 100%;
    box-sizing: border-box;
    border: 1px solid var(--ls-faq-border, #1e1e2e);
  }

  .ls-faq-item__summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    min-height: 44px;
    padding: 16px 24px;
    cursor: pointer;
    list-style: none;
  }

  /* Hide the native disclosure triangle */
  .ls-faq-item__summary::-webkit-details-marker {
    display: none;
  }
  .ls-faq-item__summary::marker {
    content: "";
  }

  .ls-faq-item__q {
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 1.65px;
    line-height: 1.3;
    text-transform: uppercase;
    text-align: left;
    color: var(--ls-faq-q, #9ca0b8);
  }

  .ls-faq-item__icon {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: var(--ls-faq-icon, #7e9de4);
    transition: transform 0.2s ease;
  }

  .ls-faq-item[open] .ls-faq-item__icon {
    transform: rotate(180deg);
  }

  .ls-faq-item__a {
    padding: 0 24px 24px;
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: 16px;
    line-height: 26px;
    color: var(--ls-faq-a, #eae8f0);
    opacity: 0.9;
  }

  .ls-faq-item__a > :first-child {
    margin-top: 0;
  }
  .ls-faq-item__a > :last-child {
    margin-bottom: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LS FAQ Item",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "question",
      "label": "Question",
      "default": "Is there a dress code?"
    },
    {
      "type": "richtext",
      "id": "answer",
      "label": "Answer",
      "default": "<p>Nope. Come as you are. Game day jersey, work clothes, boots — whatever gets you here.</p>"
    },
    {
      "type": "checkbox",
      "id": "open_by_default",
      "label": "Open by default",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "LS FAQ Item",
      "category": "t:categories.custom"
    }
  ]
}
{% endschema %}
