{%- comment -%}
  An optional sub-group ("Draft", "Canned", …) inside an LS Picture Beverage
  category. Has its own heading and holds picture beverage items in a column
  grid. Categories can use these type blocks OR hold items directly.
{%- endcomment -%}

{%- liquid
  assign b = block.settings
-%}

<div class="ls-pic-type" {{ block.shopify_attributes }}>
  {%- if b.heading != blank -%}
    <p class="ls-pic-type__heading">{{ b.heading }}</p>
  {%- endif -%}
  <div class="ls-pic-type__grid" style="--ls-pic-rows: {{ b.max_rows }};">
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .ls-pic-type {
    display: flex;
    flex-direction: column;
    gap: 32px;
    width: 100%;
  }

  .ls-pic-type__heading {
    margin: 0;
    font-family: var(--font-cormorant-garamond-italic--family, 'Cormorant Garamond', serif);
    font-style: italic;
    font-weight: var(--font-cormorant-garamond-italic--weight, 400);
    font-size: clamp(36px, 6vw, 56px);
    line-height: 0.8;
    letter-spacing: -0.05em;
    color: var(--ls-menu-subtitle, #b8c8f2);
  }

  /* Same column-major flow as the category grid. */
  .ls-pic-type__grid {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(var(--ls-pic-rows, 6), auto);
    grid-auto-columns: minmax(0, 392px);
    gap: 12px 32px;
    width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ls-pic-type__grid {
      grid-auto-flow: row;
      grid-template-rows: none;
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LS Picture Beverage Type",
  "tag": null,
  "blocks": [
    { "type": "ls-picture-beverage-item" }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Type heading",
      "info": "Italic sub-group label, e.g. Draft or Canned.",
      "default": "Draft"
    },
    {
      "type": "range",
      "id": "max_rows",
      "label": "Max rows per column",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 6,
      "info": "Items fill a column top-to-bottom up to this many rows, then start a new column."
    }
  ],
  "presets": [
    {
      "name": "LS Picture Beverage Type",
      "category": "t:categories.custom",
      "blocks": [
        { "type": "ls-picture-beverage-item", "settings": { "name": "Budweiser" } },
        { "type": "ls-picture-beverage-item", "settings": { "name": "Coors Light" } }
      ]
    }
  ]
}
{% endschema %}
