{%- liquid
  assign s = block.settings
-%}
<div
  class="ls-button-wrap"
  {{ block.shopify_attributes }}
  style="--ls-btn-align: {{ s.alignment }};"
>
  <a
    class="ls-button ls-button--{{ s.style }}{% if s.full_width %} ls-button--full{% endif %}"
    href="{{ s.link | default: '#' }}"
    {% if s.open_in_new_tab %}target="_blank" rel="noopener"{% endif %}
    style="
      --ls-btn-font: {{ s.font_family }};
      --ls-btn-size: {{ s.font_size }}px;
      --ls-btn-ls: {{ s.letter_spacing }}px;
      --ls-btn-transform: {{ s.text_transform }};
      --ls-btn-bg: {{ s.bg_color }};
      --ls-btn-text: {{ s.text_color }};
      --ls-btn-border: {{ s.border_color }};
      --ls-btn-bg-hover: {{ s.bg_hover_color }};
      --ls-btn-text-hover: {{ s.text_hover_color }};
      {% render 'spacing-style', settings: block.settings %}
    "
  >
    {{ s.label }}
  </a>
</div>

{% stylesheet %}
  .ls-button-wrap {
    display: flex;
    justify-content: var(--ls-btn-align, flex-start);
    width: 100%;
  }

  .ls-button {
    --pad-bs: var(--padding-block-start, 1rem);
    --pad-be: var(--padding-block-end, 1rem);
    --pad-is: var(--padding-inline-start, 1.5rem);
    --pad-ie: var(--padding-inline-end, 1.5rem);

    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    padding: var(--pad-bs) var(--pad-ie) var(--pad-be) var(--pad-is);
    font-family: var(--ls-btn-font, var(--font-body--family));
    font-size: var(--ls-btn-size, 16px);
    font-weight: 500;
    line-height: 1.5;
    letter-spacing: var(--ls-btn-ls, 2.4px);
    text-transform: var(--ls-btn-transform, uppercase);
    text-decoration: none;
    border: 1px solid transparent;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }

  .ls-button--full {
    width: 100%;
  }

  /* Filled */
  .ls-button--filled {
    background-color: var(--ls-btn-bg, #0b4bba);
    color: var(--ls-btn-text, #eae8f0);
  }
  .ls-button--filled:hover {
    background-color: var(--ls-btn-bg-hover, var(--ls-btn-text, #eae8f0));
    color: var(--ls-btn-text-hover, var(--ls-btn-bg, #0b4bba));
  }

  /* Outline */
  .ls-button--outline {
    background-color: transparent;
    color: var(--ls-btn-bg, #0b4bba);
    border-color: var(--ls-btn-border, var(--ls-btn-bg, #0b4bba));
  }
  .ls-button--outline:hover {
    background-color: var(--ls-btn-bg-hover, var(--ls-btn-bg, #0b4bba));
    color: var(--ls-btn-text-hover, #eae8f0);
  }

  /* Underline link (replaces the `a { text-decoration: underline; … }` hack) */
  .ls-button--link {
    padding-inline: 0;
    background: transparent;
    border: 0;
    color: var(--ls-btn-text, currentColor);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .ls-button--link:hover {
    color: var(--ls-btn-text-hover, var(--ls-btn-text, currentColor));
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LS Button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Get Directions"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open in new tab",
      "default": false
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "style",
      "label": "Style",
      "options": [
        { "value": "filled", "label": "Filled" },
        { "value": "outline", "label": "Outline" },
        { "value": "link", "label": "Underline link" }
      ],
      "default": "filled"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "flex-start", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "flex-end", "label": "Right" }
      ],
      "default": "flex-start"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "header",
      "content": "Type"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font",
      "options": [
        { "value": "var(--font-body--family)", "label": "Body (DM Sans)" },
        { "value": "var(--font-heading--family)", "label": "Heading" },
        { "value": "var(--font-gashroad--family)", "label": "Gashroad" },
        { "value": "var(--font-cormorant-garamond--family)", "label": "Cormorant Garamond" },
        { "value": "var(--font-accent--family)", "label": "Accent" }
      ],
      "default": "var(--font-body--family)"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 6,
      "step": 0.1,
      "unit": "px",
      "default": 2.4
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Case",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "UPPERCASE" },
        { "value": "lowercase", "label": "lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background / accent",
      "default": "#0b4bba"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#eae8f0"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border (outline style)",
      "default": "#0b4bba"
    },
    {
      "type": "color",
      "id": "bg_hover_color",
      "label": "Background (hover)"
    },
    {
      "type": "color",
      "id": "text_hover_color",
      "label": "Text (hover)"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "LS Button",
      "category": "t:categories.custom"
    }
  ]
}
{% endschema %}
