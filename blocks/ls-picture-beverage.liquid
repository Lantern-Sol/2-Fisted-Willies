{%- liquid
  assign b = block.settings
  assign anchor = b.anchor | strip | remove: '#'
  if anchor == blank
    assign anchor = 'ls-menu-cat-' | append: block.id
  endif
-%}

<div
  class="ls-menu-cat ls-pic-beverage"
  id="{{ anchor }}"
  data-ls-menu-cat
  style="--ls-pic-img-height: {{ b.logo_height }}px; --ls-pic-item-gap-mobile: {{ b.item_gap_mobile }}px; --ls-pic-row-gap: {{ b.row_gap }}px;"
  {{ block.shopify_attributes }}
>
  {%- if b.index_label != blank or b.title != blank -%}
    <div class="ls-menu-cat__head">
      {%- if b.index_label != blank -%}
        <p class="ls-menu-cat__index">{{ b.index_label }}</p>
      {%- endif -%}
      {%- if b.title != blank -%}
        <h3 class="ls-menu-cat__title">{{ b.title }}</h3>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- if b.subtitle != blank -%}
    <p class="ls-pic-beverage__subtitle">{{ b.subtitle }}</p>
  {%- endif -%}

  <div class="ls-pic-beverage__grid" style="--ls-pic-rows: {{ b.max_rows }};">
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .ls-pic-beverage__subtitle {
    margin: 0;
    font-family: var(--font-cormorant-garamond-italic--family, 'Cormorant Garamond', serif);
    font-style: italic;
    font-weight: var(--font-cormorant-garamond-italic--weight, 400);
    font-size: clamp(36px, 6vw, 56px);
    line-height: 0.8;
    letter-spacing: -0.05em;
    color: var(--ls-menu-subtitle, #b8c8f2);
  }

  /* Fill each column top -> bottom up to the max rows, then wrap to the next column. */
  .ls-pic-beverage__grid {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(var(--ls-pic-rows, 6), auto);
    grid-auto-columns: minmax(0, 392px);
    gap: var(--ls-pic-row-gap, 12px) 32px;
    width: 100%;
  }

  /* When the items are grouped into type blocks (Draft / Canned), stack the
     type blocks vertically — each type renders its own column grid. */
  .ls-pic-beverage__grid:has(.ls-pic-type) {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Stack into a single column on mobile. */
  @media screen and (max-width: 749px) {
    .ls-pic-beverage__grid {
      grid-auto-flow: row;
      grid-template-rows: none;
      grid-template-columns: 1fr;
      row-gap: var(--ls-pic-item-gap-mobile, 12px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LS Picture Beverage",
  "tag": null,
  "blocks": [
    { "type": "ls-picture-beverage-type" },
    { "type": "ls-picture-beverage-item" }
  ],
  "settings": [
    {
      "type": "text",
      "id": "index_label",
      "label": "Index label",
      "default": "★ 03"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Category title",
      "info": "Leave blank to continue a previous category (e.g. a second sub-group).",
      "default": "Beer List"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "info": "Italic sub-group label shown above items added directly here. Leave blank if you're using Type blocks instead.",
      "default": "Canned"
    },
    {
      "type": "range",
      "id": "logo_height",
      "label": "Logo / picture height",
      "min": 12,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 30,
      "info": "Applies to items added directly here. Items inside a Type block follow the Type's height instead. Each item can still override it."
    },
    {
      "type": "range",
      "id": "max_rows",
      "label": "Max rows per column",
      "min": 1,
      "max": 20,
      "step": 1,
      "default": 6,
      "info": "Items fill a column top-to-bottom up to this many rows, then start a new column."
    },
    {
      "type": "range",
      "id": "row_gap",
      "label": "Row gap (desktop)",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 12,
      "info": "Vertical space between items within a column on desktop."
    },
    {
      "type": "range",
      "id": "item_gap_mobile",
      "label": "Item gap (mobile)",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 12,
      "info": "Vertical space between items when stacked in a single column on mobile."
    },
    {
      "type": "text",
      "id": "anchor",
      "label": "Anchor ID",
      "info": "A unique id for this category, e.g. beer (no #). Type the same value in a nav link's \"Scroll to\" field to link to it."
    }
  ],
  "presets": [
    {
      "name": "LS Picture Beverage",
      "category": "t:categories.custom",
      "blocks": [
        { "type": "ls-picture-beverage-item", "settings": { "name": "Budweiser" } },
        { "type": "ls-picture-beverage-item", "settings": { "name": "Coors Light" } }
      ]
    }
  ]
}
{% endschema %}
