          "blocks": {
            "ls_faq_item_KBMbNN": {
              "type": "ls-faq-item",
              "settings": {
                "question": "How long has 2 Fisted Willie's been around?",
                "answer": "<p>90 years and counting. We're not a themed bar trying to look old — we're the real thing, and we've been a Chevy Chase staple longer than most folks have been alive.</p>",
                "open_by_default": false
              },
              "blocks": {}
            },
            "ls_faq_item_yQXdcq": {
              "type": "ls-faq-item",
              "settings": {
                "question": "Where are you located?",
                "answer": "<p>Right in the heart of Lexington's neighborhood, steps from the University of Kentucky campus and Kroger Field, over the corner of Woodland and Euclid.</p>",
                "open_by_default": false
              },
              "blocks": {}
            },
            "ls_faq_item_fgAb6a": {
              "type": "ls-faq-item",
              "settings": {
                "question": "What are your hours?",
                "answer": "<p>We're open daily, except Sundays, with live music every Friday and Saturday night. Hours are Thu–Sat: 4PM – 2AM, and Mon – Tue 4PM – 12AM.</p>",
                "open_by_default": false
              },
              "blocks": {}
            },
            "ls_faq_item_mPme6F": {
              "type": "ls-faq-item",
              "settings": {
                "question": "Can I bring outside food?",
                "answer": "<p>Absolutely. There's a Great Bagel, Wing Stop, and Subway right in the same center, so grab what you want and bring it on in. We're a bar first — the food's on you, the drinks are on us.</p>",
                "open_by_default": false
              },
              "blocks": {}
            },
            "ls_faq_item_JiTwVD": {
