        "ls_faq_category_FJRL4T": {
          "type": "ls-faq-category",
          "settings": {
            "heading": "PRIVATE EVENTS"
          },
          "blocks": {
            "ls_faq_item_KTtriz": {
              "type": "ls-faq-item",
              "settings": {
                "question": "Can I rent the venue for a private party?",
                "answer": "<p>You bet! Birthdays, corporate buyouts, game day groups, you name it — we've got the space and the setup to do it right. Fill out the form on our Private Events page and we'll get back to you to schedule your fun.</p>",
                "open_by_default": false
              },
              "blocks": {}
            },
            "ls_faq_item_QEkzxX": {
              "type": "ls-faq-item",
              "settings": {
                "question": "How many guests can you fit?",
                "answer": "<p>Capacity depends on the space and setup. Tell us your headcount in the Private Events inquiry and we'll let you know what works best.</p>",
                "open_by_default": false
              },
              "blocks": {}
            },
            "ls_faq_item_AFFWeF": {
              "type": "ls-faq-item",
              "settings": {
                "question": "Can you set up live music or a DJ for my event?",
                "answer": "<p>We've got professional sound engineers and talent booking in-house, so live music or a DJ is absolutely on the table. Just let us know what vibe you're after in your inquiry.</p>",
                "open_by_default": false
              },
              "blocks": {}
            },
            "ls_faq_item_YRAz6K": {
              "type": "ls-faq-item",
              "settings": {
                "question": "How far in advance should I book?",
                "answer": "<p>The sooner the better — weekends and game days fill up fast and we traditionally host private events Sunday - Wednesday. Get your inquiry in early so we can lock down your date.</p>",
                "open_by_default": false
              },
              "blocks": {}
            }
          },
          "block_order": [
