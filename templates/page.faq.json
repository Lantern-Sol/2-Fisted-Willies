        "ls_faq_category_xQ9qXJ": {
          "type": "ls-faq-category",
          "settings": {
            "heading": "TICKETS & EVENTS"
          },
          "blocks": {
            "ls_faq_item_nbtUNf": {
              "type": "ls-faq-item",
              "settings": {
                "question": "How do I buy tickets for a show?",
                "answer": "<p>Head to our Events page, find the show you want, and either pay at the door, through the Line Leap app, or for our larger ticketed events grab tickets under the Events tab. Touring acts and Special Events are ticketed in advance; smaller shows will have a Live Music cover at the door that you may handle through Line Leap or when you arrive. </p>",
                "open_by_default": false
              },
              "blocks": {}
            },
            "ls_faq_item_rn8TaT": {
              "type": "ls-faq-item",
              "settings": {
                "question": "Do you have live music every weekend?",
                "answer": "<p>Every Friday and Saturday night, year-round. Local college bands, DJs, and nationally touring artists — the guitars never stop at Willie's.</p>",
                "open_by_default": false
              },
              "blocks": {}
            },
            "ls_faq_item_eWCLWA": {
              "type": "ls-faq-item",
              "settings": {
                "question": "Can I get a refund on tickets?",
                "answer": "<p>Refund policies depend on the event and the ticketing platform. Reach out before the show and we'll point you in the right direction.</p>",
                "open_by_default": false
              },
              "blocks": {}
            }
          },
          "block_order": [
            "ls_faq_item_nbtUNf",
