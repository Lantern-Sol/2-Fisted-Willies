          "blocks": {
            "ls_faq_item_nbtUNf": {
              "type": "ls-faq-item",
              "settings": {
                "question": "How do I buy tickets for a show?",
                "answer": "<p>Head to our Events page, find the show you want, and grab tickets right there. Bigger touring acts are ticketed in advance; smaller shows may just have a cover at the door.</p>",
                "open_by_default": true
              },
              "blocks": {}
            },
            "ls_faq_item_rn8TaT": {
              "type": "ls-faq-item",
              "settings": {
                "question": "Do you have live music every weekend?",
                "answer": "<p>Every Friday and Saturday night, year-round. Local college bands, DJs, and nationally touring artists — the guitar never stops at Willie's.</p>",
                "open_by_default": true
              },
              "blocks": {}
            },
            "ls_faq_item_eWCLWA": {
              "type": "ls-faq-item",
              "settings": {
                "question": "Can I get a refund on tickets?",
                "answer": "<p>Refund policies depend on the event and the ticketing platform. Reach out before the show and we'll point you in the right direction.</p>",
                "open_by_default": true
              },
              "blocks": {}
            }
          },
          "block_order": [
            "ls_faq_item_nbtUNf",
