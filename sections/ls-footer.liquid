  ],
  "presets": [
    {
      "name": "LS Footer",
      "category": "t:categories.other_sections",
      "blocks": [
        { "type": "link", "settings": { "label": "Events" } },
        { "type": "link", "settings": { "label": "Tickets" } },
        { "type": "link", "settings": { "label": "Reservations" } },
        { "type": "link", "settings": { "label": "Menu" } },
        { "type": "link", "settings": { "label": "Private Events" } },
        { "type": "link", "settings": { "label": "About" } }
      ]
    }
  ]
}
{% endschema %}
