{% liquid
  assign s = section.settings
%}

<div class="section-background ls-events__bg"></div>
<div
  class="section ls-events ls-events--featured spacing-style"
  data-eventbrite-token="{{ s.eventbrite_token | escape }}"
  data-eventbrite-org-id="{{ s.eventbrite_organization_id | escape }}"
  data-eventbrite-hide-when-empty="{{ s.hide_when_empty }}"
  style="{% render 'spacing-style', settings: section.settings %}{% render 'ls-events-theme-vars', settings: section.settings %}"
>
  <div class="ls-events__inner">
    {%- if s.heading != blank -%}
      <h2 class="ls-events__section-label">{{ s.heading }}</h2>
    {%- endif -%}

    <p class="ls-events__empty" data-eventbrite-loading>Loading events…</p>

    <div
      class="ls-events__featured-list"
      data-eventbrite-grid
      data-eventbrite-layout="featured"
      data-eventbrite-date-filter="upcoming"
      data-eventbrite-status="live"
      data-eventbrite-sort="asc"
      data-eventbrite-featured-ids="{{ s.featured_event_ids | escape }}"
    ></div>

    <p class="ls-events__empty" data-eventbrite-empty{% if s.hide_when_empty %} hidden{% endif %}>No featured events right now.</p>
    <p class="ls-events__empty" data-eventbrite-error hidden></p>
  </div>
</div>

{% render 'ls-events-styles' %}

{% stylesheet %}
  .ls-events__section-label {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.65px;
    text-transform: uppercase;
    color: var(--ls-events-muted, #9ca0b8);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LS Events — Featured",
  "tag": "section",
  "class": "ls-events-featured-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "Loads featured events from Eventbrite. List Eventbrite event IDs below (comma-separated). Leave blank to show all upcoming live events."
    },
    {
      "type": "text",
      "id": "eventbrite_token",
      "label": "Eventbrite API token"
    },
    {
      "type": "text",
      "id": "eventbrite_organization_id",
      "label": "Eventbrite organization ID",
      "default": "3004670821317"
    },
    {
      "type": "text",
      "id": "featured_event_ids",
      "label": "Featured event IDs",
      "info": "Comma-separated Eventbrite event IDs. Leave blank to show all upcoming events."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section label (optional)",
      "info": "Leave blank for no label above the cards."
    },
    {
      "type": "checkbox",
      "id": "hide_when_empty",
      "label": "Hide section when no featured events",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#0e1018"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#eae8f0"
    },
    {
      "type": "color",
      "id": "heading_accent_color",
      "label": "Heading accent",
      "default": "#7e9de4"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle / genre",
      "default": "#9ca0b8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text",
      "default": "#eae8f0"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#9ca0b8"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#141824"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card border",
      "default": "#9ca0b8"
    },
    {
      "type": "color",
      "id": "diamond_color",
      "label": "Diamond accent line",
      "default": "#0033a0"
    },
    {
      "type": "color",
      "id": "cta_bg",
      "label": "CTA background",
      "default": "#0b4bba"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "CTA text",
      "default": "#eae8f0"
    },
    {
      "type": "color",
      "id": "filter_border",
      "label": "Filter border",
      "default": "#3d4a66"
    },
    {
      "type": "color",
      "id": "filter_active_bg",
      "label": "Filter active background",
      "default": "#1a2540"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "LS Events — Featured",
      "category": "t:categories.other_sections"
    }
  ]
}
{% endschema %}
