{% liquid
  assign s = section.settings
  assign today = 'now' | date: '%Y-%m-%d'
  assign all_events = '' | split: ''
  assign featured_count = 0
%}

{% paginate shop.metaobjects.event.values by 50 %}
  {% assign all_events = shop.metaobjects.event.values %}
{% endpaginate %}
{% if all_events.size == 0 %}
  {% paginate metaobjects.event.values by 50 %}
    {% assign all_events = metaobjects.event.values %}
  {% endpaginate %}
{% endif %}

{% render 'ls-events-load', settings: s %}

{%- for event in all_events -%}
  {%- capture event_date -%}{%- render 'ls-event-date-string', event: event -%}{%- endcapture -%}
  {%- assign event_date = event_date | strip -%}
  {%- if event_date != blank and event_date >= today -%}
    {%- capture featured_flag -%}{%- render 'ls-event-is-featured', event: event -%}{%- endcapture -%}
    {%- if featured_flag contains 'true' -%}
      {%- assign featured_count = featured_count | plus: 1 -%}
    {%- endif -%}
  {%- endif -%}
{%- endfor -%}

{%- if featured_count > 0 or s.hide_when_empty == false -%}
<div class="section-background ls-events__bg"></div>
<div
  class="section ls-events ls-events--featured spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}{% render 'ls-events-theme-vars', settings: section.settings %}"
>
  <div class="ls-events__inner">
    {%- if s.heading != blank -%}
      <h2 class="ls-events__section-label">{{ s.heading }}</h2>
    {%- endif -%}

    {%- if featured_count > 0 -%}
      <div class="ls-events__featured-list">
        {%- for event in all_events -%}
          {%- capture event_date -%}{%- render 'ls-event-date-string', event: event -%}{%- endcapture -%}
          {%- assign event_date = event_date | strip -%}
          {%- if event_date != blank and event_date >= today -%}
            {%- capture featured_flag -%}{%- render 'ls-event-is-featured', event: event -%}{%- endcapture -%}
            {%- if featured_flag contains 'true' -%}
              {% render 'ls-event-card', event: event, layout: 'featured' %}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- elsif s.hide_when_empty == false -%}
      <p class="ls-events__empty">No featured events right now.</p>
    {%- endif -%}
  </div>
</div>
{%- endif -%}

{% render 'ls-events-styles' %}

{% stylesheet %}
  .ls-events__section-label {
    margin: 0;
    font-family: var(--font-body--family);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 1.65px;
    text-transform: uppercase;
    color: var(--ls-events-muted, #9ca0b8);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LS Events — Featured",
  "tag": "section",
  "class": "ls-events-featured-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section label (optional)",
      "info": "Leave blank for no label above the cards."
    },
    {
      "type": "checkbox",
      "id": "hide_when_empty",
      "label": "Hide section when no featured events",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_debug",
      "label": "Show debug panel",
      "default": false
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#0e1018"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#eae8f0"
    },
    {
      "type": "color",
      "id": "heading_accent_color",
      "label": "Heading accent",
      "default": "#7e9de4"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle / genre",
      "default": "#9ca0b8"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text",
      "default": "#eae8f0"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Muted text",
      "default": "#9ca0b8"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#141824"
    },
    {
      "type": "color",
      "id": "card_border",
      "label": "Card border",
      "default": "#2a3348"
    },
    {
      "type": "color",
      "id": "cta_bg",
      "label": "CTA background",
      "default": "#0b4bba"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "CTA text",
      "default": "#eae8f0"
    },
    {
      "type": "color",
      "id": "filter_border",
      "label": "Filter border",
      "default": "#3d4a66"
    },
    {
      "type": "color",
      "id": "filter_active_bg",
      "label": "Filter active background",
      "default": "#1a2540"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "LS Events — Featured",
      "category": "t:categories.other_sections"
    }
  ]
}
{% endschema %}
