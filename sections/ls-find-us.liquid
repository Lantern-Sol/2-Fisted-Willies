      "info": "Optional paper/cardstock texture. Falls back to the baked-in grain + color."
    },
    {
      "type": "color",
      "id": "parking_border",
      "label": "Parking border",
      "default": "#3b6bd6"
    },
    {
      "type": "color",
      "id": "parking_text_color",
      "label": "Parking text",
      "default": "#b8c8f2"
    },
    {
      "type": "color",
      "id": "parking_bg_mobile",
      "label": "Parking background (mobile)",
      "default": "#151c33"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 128
    }
  ],
  "presets": [
    {
      "name": "LS Find Us",
      "category": "t:categories.other_sections"
    }
  ]
}
{% endschema %}
