  "tag": "section",
  "class": "ls-about-hero-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    { "type": "@theme" },
    { "type": "@app" }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#1e1e2e"
    },
    {
      "type": "color",
      "id": "bg_gradient_color",
      "label": "Gradient sink (bottom)",
      "default": "#0a0c12"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Faint background photo",
      "info": "Shown at 10% opacity behind everything."
