      "type": "image_picker",
      "id": "character",
      "label": "Character image",
      "info": "Sits above the heading. Falls back to the built-in Willie artwork."
    },
    {
      "type": "range",
      "id": "character_width",
      "label": "Character width",
      "min": 100,
      "max": 400,
      "step": 4,
